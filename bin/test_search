#!/usr/bin/env ruby
# frozen_string_literal: true

# Quick test: discover vaults from a root directory and run a search.
# Useful for verifying the pipeline works before connecting to Claude Desktop.
#
# Usage:
#   ruby bin/test_search <root_directory> <vault_name> <search_query> [limit]
#
# Example:
#   ruby bin/test_search /vault Drakkenheim "undead in the ruins" 5

require_relative "../lib/embedder"
require_relative "../lib/vector_store"
require_relative "../lib/indexer"

if ARGV.length < 3
  puts "Usage: ruby bin/test_search <root_directory> <vault_name> <search_query> [limit]"
  exit 1
end

root       = File.expand_path(ARGV[0])
vault_name = ARGV[1]
query      = ARGV[2]
limit      = (ARGV[3] || 5).to_i

db_url = ENV.fetch("DATABASE_URL", "postgresql://localhost/obsidian_rag")

embedder = MarkdownMcp::Embedder.new
store    = MarkdownMcp::VectorStore.new(db_url: db_url)
indexer  = MarkdownMcp::Indexer.new(embedder: embedder, store: store)

store.setup!

subdirs = Dir.entries(root)
  .reject { |e| e.start_with?(".") }
  .map { |e| File.join(root, e) }
  .select { |e| File.directory?(e) }
  .sort

puts "Discovering #{subdirs.size} vault(s) from #{root}..."
subdirs.each do |dir|
  name = File.basename(dir)
  store.register_vault(name, dir)
  stats = indexer.index(directory: dir, vault_name: name)
  puts "  #{name}: #{stats[:files_indexed]} files indexed, #{stats[:chunks_added]} chunks added"
end
puts ""

puts "Searching vault '#{vault_name}' for: '#{query}'"
puts "---"
query_embedding = embedder.embed(query)
results = store.search(query_embedding, vault_name: vault_name, limit: limit)

if results.empty?
  puts "No results. Is the vault indexed and does it have matching content?"
else
  results.each_with_index do |r, i|
    puts "Result #{i + 1} (distance: #{r[:distance].round(4)})"
    puts "  File: #{r[:file_path]}"
    puts "  Title: #{r[:doc_title]}"
    puts "  Section: #{r[:heading]}" if r[:heading]
    puts "  Content preview: #{r[:content][0..200]}..."
    puts ""
  end
end
